@{
    var requestType = RequestDisplay.RequestType(Request.RequestType?.Name);
}

@* List item card for the master-detail dashboard (root CLAUDE.md §7):
     Request Name v4.2                       [In Review]
     System · ID 3001 · Parent — · Requestor John Smith
     2026-05-25                              💬 4
   The enum-backed type badge uses the same color mapping as the Type filter chips. *@
<button type="button" class="request-card @(Selected ? "request-card-selected" : "")" @onclick="() => OnSelect.InvokeAsync(Request.RequestId)">
    <div class="request-card-row1">
        <span class="request-card-title-group">
            <span class="request-type-badge @RequestDisplay.RequestTypeClass(Request.RequestType?.Name)"
                  title="@requestType.Name"
                  aria-label="@requestType.Name">@requestType.Abbreviation</span>
            <span class="request-card-title">@Request.Title @Request.Version</span>
        </span>
        <TelerikChip Text="@(Request.RequestStatus?.Name ?? "—")"
                     Class="@RequestDisplay.RequestStatusClass(Request.RequestStatus?.Name)" />
    </div>
    <div class="request-card-row2">
        @Request.RequestType?.Name · ID @Request.RequestId · Parent @(Request.ParentRequest?.Title ?? "—") · Requestor @(Request.Requestor?.FullName ?? "—")
    </div>
    <div class="request-card-row3">
        <span>@Request.LogDate.ToString("yyyy-MM-dd")</span>
        <span class="request-card-notes">💬 @NoteCount</span>
    </div>
</button>

@code {
    [Parameter, EditorRequired]
    public Request Request { get; set; } = default!;

    [Parameter]
    public bool Selected { get; set; }

    [Parameter]
    public int NoteCount { get; set; }

    [Parameter]
    public EventCallback<int> OnSelect { get; set; }
}
