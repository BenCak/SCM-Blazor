@inject ICurrentUserService CurrentUser

@* Inline accordion navigation: section children expand downward inside the drawer
   instead of opening in TelerikMenu's side-facing popup. *@
<nav class="scm3-nav" aria-label="Main navigation">
    @foreach (var item in _items)
    {
        var isOpen = _openSections.Contains(item.Text);
        var sectionId = $"nav-section-{item.Text.Replace(" ", "-", StringComparison.Ordinal).ToLowerInvariant()}";

        <div class="scm3-nav-section">
            <button type="button"
                    class="scm3-nav-row scm3-nav-section-button"
                    title="@(!Expanded ? item.Text : null)"
                    aria-expanded="@isOpen"
                    aria-controls="@sectionId"
                    @onclick="() => ToggleSection(item.Text)">
                <span class="scm3-nav-icon" aria-hidden="true">
                    <TelerikSvgIcon Icon="@item.Icon" />
                </span>
                <span class="@(!Expanded ? "visually-hidden" : "scm3-nav-label")">@item.Text</span>
                @if (Expanded)
                {
                    <span class="scm3-nav-chevron" aria-hidden="true">
                        <TelerikSvgIcon Icon="@(isOpen ? Telerik.SvgIcons.SvgIcon.ChevronUp : Telerik.SvgIcons.SvgIcon.ChevronDown)" />
                    </span>
                }
            </button>

            @if (isOpen && item.Items is not null)
            {
                <div id="@sectionId" class="scm3-nav-children">
                    @foreach (var child in item.Items)
                    {
                        <NavLink href="@child.Url"
                                 class="scm3-nav-row scm3-nav-link"
                                 Match="@NavLinkMatch.All"
                                 title="@(!Expanded ? child.Text : null)">
                            <span class="scm3-nav-icon" aria-hidden="true">
                                <TelerikSvgIcon Icon="@child.Icon" />
                            </span>
                            <span class="@(!Expanded ? "visually-hidden" : "scm3-nav-label")">@child.Text</span>
                        </NavLink>
                    }
                </div>
            }
        </div>
    }
</nav>

@code {
    // Drives icon-only (collapsed, 50px) vs icon+label (expanded, 200px) display —
    // root CLAUDE.md §8.
    [Parameter]
    public bool Expanded { get; set; } = true;

    private sealed class NavMenuItem
    {
        public string Text { get; set; } = string.Empty;
        public Telerik.SvgIcons.ISvgIcon Icon { get; set; } = Telerik.SvgIcons.SvgIcon.Circle;
        public string? Url { get; set; }
        public List<NavMenuItem>? Items { get; set; }
    }

    private List<NavMenuItem> _items = [];
    private readonly HashSet<string> _openSections = ["Release Artifacts"];

    // MainLayout also calls LoadAsync, but its completion doesn't trigger a re-render
    // here (NavMenu's parameters haven't changed) — load independently so role checks
    // below see a populated CurrentUser on NavMenu's own first render. LoadAsync is
    // idempotent (no-ops once CurrentUser is set), so this is cheap either way.
    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.LoadAsync();
        _items = BuildItems();
    }

    private List<NavMenuItem> BuildItems()
    {
        var isScm = CurrentUser.IsInRole("SCM_Staff", "SCM_Admin");

        var releaseArtifacts = new NavMenuItem
        {
            Text = "Release Artifacts",
            Icon = Telerik.SvgIcons.SvgIcon.Clipboard,
            Items =
            [
                new NavMenuItem { Text = "All Requests", Icon = Telerik.SvgIcons.SvgIcon.ListUnordered, Url = "/requests" }
            ]
        };

        var viewerTools = new NavMenuItem
        {
            Text = "Viewer Tools",
            Icon = Telerik.SvgIcons.SvgIcon.Wrench,
            Items =
            [
                new NavMenuItem { Text = "Lineage Tree", Icon = Telerik.SvgIcons.SvgIcon.Graph, Url = "/tools/lineage-tree" },
                new NavMenuItem { Text = "Release Documents", Icon = Telerik.SvgIcons.SvgIcon.File, Url = "/tools/release-documents" }
            ]
        };
        if (isScm)
        {
            viewerTools.Items!.Add(new NavMenuItem { Text = "Release Tools", Icon = Telerik.SvgIcons.SvgIcon.Launch, Url = "/tools/release-tools" });
            viewerTools.Items!.Add(new NavMenuItem { Text = "Compare Tools", Icon = Telerik.SvgIcons.SvgIcon.Search, Url = "/tools/compare-tools" });
        }

        var items = new List<NavMenuItem> { releaseArtifacts, viewerTools };

        if (isScm)
        {
            items.Add(new NavMenuItem
            {
                Text = "SCM DB Manager",
                Icon = Telerik.SvgIcons.SvgIcon.Data,
                Items =
                [
                    new NavMenuItem { Text = "Customers", Icon = Telerik.SvgIcons.SvgIcon.Buildings, Url = "/admin/db/customers" },
                    new NavMenuItem { Text = "Products", Icon = Telerik.SvgIcons.SvgIcon.Cube, Url = "/admin/db/products" },
                    new NavMenuItem { Text = "Systems", Icon = Telerik.SvgIcons.SvgIcon.Devices, Url = "/admin/db/systems" },
                    new NavMenuItem { Text = "CSCI Names", Icon = Telerik.SvgIcons.SvgIcon.PuzzlePiece, Url = "/admin/db/csci-names" },
                    new NavMenuItem { Text = "Segment Names", Icon = Telerik.SvgIcons.SvgIcon.Link, Url = "/admin/db/segment-names" },
                    new NavMenuItem { Text = "Manufacturers", Icon = Telerik.SvgIcons.SvgIcon.IndustrialVehicle, Url = "/admin/db/manufacturers" },
                    new NavMenuItem { Text = "Units", Icon = Telerik.SvgIcons.SvgIcon.Ruler, Url = "/admin/db/units" }
                ]
            });
        }

        if (CurrentUser.IsInRole("SCM_Admin"))
        {
            items.Add(new NavMenuItem
            {
                Text = "Admin",
                Icon = Telerik.SvgIcons.SvgIcon.Gear,
                Items =
                [
                    new NavMenuItem { Text = "Manage Users", Icon = Telerik.SvgIcons.SvgIcon.Users, Url = "/admin/users" },
                    new NavMenuItem { Text = "Roles & Permissions", Icon = Telerik.SvgIcons.SvgIcon.SecurityLock, Url = "/admin/roles" },
                    new NavMenuItem { Text = "Settings", Icon = Telerik.SvgIcons.SvgIcon.Sliders, Url = "/admin/settings" }
                ]
            });
        }

        return items;
    }

    private void ToggleSection(string section)
    {
        if (!_openSections.Add(section))
        {
            _openSections.Remove(section);
        }
    }
}
