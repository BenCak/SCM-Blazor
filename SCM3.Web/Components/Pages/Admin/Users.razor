@page "/admin/users"
@attribute [Authorize(Roles = "SCM_Admin")]
@inject IUserService UserService

@*
    Admin > Manage Users (root CLAUDE.md §4/§8) — SCM_Admin-only. Lets admins fix the
    role assigned to AD-synced users; the auto-create-on-first-login flow (§3) seeds new
    users as "Viewer" and notifies SCM_Admin to come adjust them here.
*@
<PageTitle>Manage Users · SCM3 Portal</PageTitle>

<div class="scm3-admin-page">
    <h1>Manage Users</h1>
    <p class="scm3-muted">Roles and contact info for every AD-synced user (root CLAUDE.md §3 — new logins are auto-created here as Viewer).</p>

    @if (_statusMessage is not null)
    {
        <p class="scm3-detail-status-message">@_statusMessage</p>
    }

    @if (_loading)
    {
        <p class="scm3-muted">Loading users…</p>
    }
    else
    {
        <TelerikGrid Data="@_users"
                     EditMode="Telerik.Blazor.GridEditMode.Inline"
                     OnUpdate="@OnUpdate">
            <GridColumns>
                <GridColumn Field="@nameof(User.Username)" Title="Username" Editable="false" />
                <GridColumn Field="@nameof(User.FullName)" Title="Full Name" />
                <GridColumn Field="@nameof(User.Email)" Title="Email" />
                <GridColumn Field="@nameof(User.Department)" Title="Department" />
                <GridColumn Field="@nameof(User.Role)" Title="Role">
                    <EditorTemplate>
                        @{ var editedUser = (User)context; }
                        <TelerikDropDownList Data="@Roles"
                                             @bind-Value="editedUser.Role"
                                             Width="100%" />
                    </EditorTemplate>
                </GridColumn>
                <GridCommandColumn>
                    <GridCommandButton Command="Edit">Edit</GridCommandButton>
                    <GridCommandButton Command="Save" ShowInEdit="true">Save</GridCommandButton>
                    <GridCommandButton Command="Cancel" ShowInEdit="true">Cancel</GridCommandButton>
                </GridCommandColumn>
            </GridColumns>
        </TelerikGrid>
    }
</div>

@code {
    private static readonly string[] Roles = ["Viewer", "TE_User", "EE_User", "SCM_Staff", "SCM_Admin"];

    private List<User> _users = [];
    private bool _loading = true;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _users = await UserService.GetAllAsync();
        _loading = false;
    }

    private async Task OnUpdate(GridCommandEventArgs args)
    {
        var user = (User)args.Item;
        _statusMessage = null;

        await UserService.SaveAsync(user);
        await LoadAsync();
        _statusMessage = $"Saved \"{user.FullName}\" - role: {user.Role}.";
    }
}
