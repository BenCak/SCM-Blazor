@page "/admin/roles"
@attribute [Authorize(Roles = "SCM_Admin")]

@*
    Admin > Roles & Permissions (root CLAUDE.md §4/§8) — read-only reference rendering of
    the permission matrix straight from the planning doc. Roles are a single fixed column
    on Users (§2 "one role per user — simple, not many-to-many"), so there's no separate
    Role entity to manage here — this page exists to let SCM_Admin look up "who can do
    what" without re-opening CLAUDE.md.
*@
<PageTitle>Roles & Permissions · SCM3 Portal</PageTitle>

<div class="scm3-admin-page">
    <h1>Roles & Permissions</h1>
    <p class="scm3-muted">
        Reference matrix (root CLAUDE.md §4) — roles are fixed and assigned one-per-user
        under <a href="/admin/users">Manage Users</a>.
    </p>

    <TelerikGrid Data="@Matrix">
        <GridColumns>
            <GridColumn Field="@nameof(PermissionRow.Action)" Title="Action" />
            <GridColumn Field="@nameof(PermissionRow.Viewer)" Title="Viewer">
                <Template>@RenderBadge(((PermissionRow)context).Viewer)</Template>
            </GridColumn>
            <GridColumn Field="@nameof(PermissionRow.TeUser)" Title="TE_User">
                <Template>@RenderBadge(((PermissionRow)context).TeUser)</Template>
            </GridColumn>
            <GridColumn Field="@nameof(PermissionRow.EeUser)" Title="EE_User">
                <Template>@RenderBadge(((PermissionRow)context).EeUser)</Template>
            </GridColumn>
            <GridColumn Field="@nameof(PermissionRow.ScmStaff)" Title="SCM_Staff">
                <Template>@RenderBadge(((PermissionRow)context).ScmStaff)</Template>
            </GridColumn>
            <GridColumn Field="@nameof(PermissionRow.ScmAdmin)" Title="SCM_Admin">
                <Template>@RenderBadge(((PermissionRow)context).ScmAdmin)</Template>
            </GridColumn>
        </GridColumns>
    </TelerikGrid>
</div>

@code {
    private record PermissionRow(string Action, string Viewer, string TeUser, string EeUser, string ScmStaff, string ScmAdmin);

    private static readonly PermissionRow[] Matrix =
    [
        new("View all requests", "✅", "Own only", "Own only", "✅", "✅"),
        new("Create request", "❌", "TE only", "EE only", "✅", "✅"),
        new("Edit request", "❌", "Own + Draft", "Own + Draft", "✅", "✅"),
        new("Delete (soft)", "❌", "❌", "❌", "❌", "✅"),
        new("Update SCM Status", "❌", "❌", "❌", "✅", "✅"),
        new("Add notes", "❌", "Own only", "Own only", "✅", "✅"),
        new("Approve / Reject", "❌", "❌", "❌", "❌", "✅"),
        new("Release", "❌", "❌", "❌", "❌", "✅"),
        new("Reopen", "❌", "❌", "❌", "❌", "✅"),
        new("View History", "✅", "Own only", "Own only", "✅", "✅"),
        new("View Change Log", "❌", "❌", "❌", "✅", "✅"),
        new("SCM DB Manager", "❌", "❌", "❌", "✅", "✅"),
        new("Admin menu", "❌", "❌", "❌", "❌", "✅"),
        new("Manage Users", "❌", "❌", "❌", "❌", "✅"),
    ];

    private RenderFragment RenderBadge(string value) => @<TelerikChip Text="@value" />;
}
