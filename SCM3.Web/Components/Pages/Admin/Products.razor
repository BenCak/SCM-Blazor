@page "/admin/db/products"
@attribute [Authorize(Roles = "SCM_Staff,SCM_Admin")]
@inject IProductService ProductService

@*
    SCM DB Manager > Products (root CLAUDE.md §8) — mirrors Customers.razor; Product is
    the same soft-deletable name shape feeding System composition (§2 hierarchy).
*@
<PageTitle>Products · SCM3 Portal</PageTitle>

<div class="scm3-admin-page">
    <h1>Products</h1>
    <p class="scm3-muted">Reference data used when composing Systems (Customer + Product).</p>

    @if (_statusMessage is not null)
    {
        <p class="scm3-detail-status-message">@_statusMessage</p>
    }

    @if (_loading)
    {
        <p class="scm3-muted">Loading products…</p>
    }
    else
    {
        <TelerikGrid Data="@_products"
                     EditMode="Telerik.Blazor.GridEditMode.Inline"
                     OnUpdate="@OnUpdate"
                     OnCreate="@OnCreate"
                     OnDelete="@OnDelete">
            <GridToolBarTemplate>
                <GridCommandButton Command="Add">Add Product</GridCommandButton>
            </GridToolBarTemplate>
            <GridColumns>
                <GridColumn Field="@nameof(Product.Name)" Title="Name" />
                <GridCommandColumn>
                    <GridCommandButton Command="Edit">Edit</GridCommandButton>
                    <GridCommandButton Command="Delete">Delete</GridCommandButton>
                    <GridCommandButton Command="Save" ShowInEdit="true">Save</GridCommandButton>
                    <GridCommandButton Command="Cancel" ShowInEdit="true">Cancel</GridCommandButton>
                </GridCommandColumn>
            </GridColumns>
        </TelerikGrid>
    }
</div>

@code {
    private List<Product> _products = [];
    private bool _loading = true;
    private bool _busy;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _products = await ProductService.GetAllAsync();
        _loading = false;
    }

    private async Task OnCreate(GridCommandEventArgs args)
    {
        var product = (Product)args.Item;
        if (string.IsNullOrWhiteSpace(product.Name)) return;
        await ProductService.SaveAsync(product);
        await LoadAsync();
        _statusMessage = $"Added \"{product.Name}\".";
    }

    private async Task OnUpdate(GridCommandEventArgs args)
    {
        var product = (Product)args.Item;
        await ProductService.SaveAsync(product);
        await LoadAsync();
        _statusMessage = $"Saved \"{product.Name}\".";
    }

    private async Task OnDelete(GridCommandEventArgs args)
    {
        var product = (Product)args.Item;
        await ProductService.DeleteAsync(product.ProductId);
        await LoadAsync();
        _statusMessage = $"Deleted \"{product.Name}\".";
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        _busy = true;
        _statusMessage = null;
        try
        {
            await action();
        }
        finally
        {
            _busy = false;
        }
    }
}
