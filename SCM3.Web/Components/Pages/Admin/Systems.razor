@page "/admin/db/systems"
@attribute [Authorize(Roles = "SCM_Staff,SCM_Admin")]
@inject ISystemService SystemService
@inject ICustomerService CustomerService
@inject IProductService ProductService

@*
    SCM DB Manager > Systems (root CLAUDE.md §8) — the Customer + Product combination
    that tops the request hierarchy (§2, e.g. "Army Gray Eagle" = Army + Gray Eagle).
    Customer/Product are foreign keys here, so this needs the lookup dropdowns that
    Customers/Products.razor don't.
*@
<PageTitle>Systems · SCM3 Portal</PageTitle>

<div class="scm3-admin-page">
    <h1>Systems</h1>
    <p class="scm3-muted">Customer + Product combinations that top the release hierarchy (e.g. "Army Gray Eagle").</p>

    @if (_statusMessage is not null)
    {
        <p class="scm3-detail-status-message">@_statusMessage</p>
    }

    @if (_loading)
    {
        <p class="scm3-muted">Loading systems…</p>
    }
    else if (_customers.Count == 0 || _products.Count == 0)
    {
        <p class="scm3-muted">Add at least one Customer and Product before creating a System.</p>
    }
    else
    {
        <TelerikGrid Data="@_systems"
                     EditMode="Telerik.Blazor.GridEditMode.Inline"
                     OnCreate="@OnCreate"
                     OnUpdate="@OnUpdate"
                     OnDelete="@OnDelete">
            <GridToolBarTemplate>
                <GridCommandButton Command="Add">Add System</GridCommandButton>
            </GridToolBarTemplate>
            <GridColumns>
                <GridColumn Field="@nameof(SystemEntity.Name)" Title="Name" />
                <GridColumn Field="@nameof(SystemEntity.CustomerId)" Title="Customer">
                    <Template>@GetCustomerName(((SystemEntity)context).CustomerId)</Template>
                    <EditorTemplate>
                        @{ var editedSystem = (SystemEntity)context; }
                        <TelerikDropDownList Data="@_customers"
                                             TextField="@nameof(Customer.Name)"
                                             ValueField="@nameof(Customer.CustomerId)"
                                             @bind-Value="editedSystem.CustomerId"
                                             Width="100%" />
                    </EditorTemplate>
                </GridColumn>
                <GridColumn Field="@nameof(SystemEntity.ProductId)" Title="Product">
                    <Template>@GetProductName(((SystemEntity)context).ProductId)</Template>
                    <EditorTemplate>
                        @{ var editedSystem = (SystemEntity)context; }
                        <TelerikDropDownList Data="@_products"
                                             TextField="@nameof(Product.Name)"
                                             ValueField="@nameof(Product.ProductId)"
                                             @bind-Value="editedSystem.ProductId"
                                             Width="100%" />
                    </EditorTemplate>
                </GridColumn>
                <GridCommandColumn>
                    <GridCommandButton Command="Edit">Edit</GridCommandButton>
                    <GridCommandButton Command="Delete">Delete</GridCommandButton>
                    <GridCommandButton Command="Save" ShowInEdit="true">Save</GridCommandButton>
                    <GridCommandButton Command="Cancel" ShowInEdit="true">Cancel</GridCommandButton>
                </GridCommandColumn>
            </GridColumns>
        </TelerikGrid>
    }
</div>

@code {
    private List<SystemEntity> _systems = [];
    private List<Customer> _customers = [];
    private List<Product> _products = [];

    private bool _loading = true;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _customers = await CustomerService.GetAllAsync();
        _products = await ProductService.GetAllAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _systems = await SystemService.GetAllAsync();
        _loading = false;
    }

    private async Task OnCreate(GridCommandEventArgs args)
    {
        var system = (SystemEntity)args.Item;
        if (string.IsNullOrWhiteSpace(system.Name)) return;

        if (system.CustomerId == 0)
        {
            system.CustomerId = _customers.First().CustomerId;
        }

        if (system.ProductId == 0)
        {
            system.ProductId = _products.First().ProductId;
        }

        await SystemService.SaveAsync(system);
        await LoadAsync();
        _statusMessage = $"Added \"{system.Name}\".";
    }

    private async Task OnUpdate(GridCommandEventArgs args)
    {
        var system = (SystemEntity)args.Item;
        await SystemService.SaveAsync(system);
        await LoadAsync();
        _statusMessage = $"Saved \"{system.Name}\".";
    }

    private async Task OnDelete(GridCommandEventArgs args)
    {
        var system = (SystemEntity)args.Item;
        await SystemService.DeleteAsync(system.SystemId);
        await LoadAsync();
        _statusMessage = $"Deleted \"{system.Name}\".";
    }

    private string GetCustomerName(int customerId)
        => _customers.FirstOrDefault(c => c.CustomerId == customerId)?.Name ?? "-";

    private string GetProductName(int productId)
        => _products.FirstOrDefault(p => p.ProductId == productId)?.Name ?? "-";
}
