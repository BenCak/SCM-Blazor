@page "/admin/db/customers"
@attribute [Authorize(Roles = "SCM_Staff,SCM_Admin")]
@inject ICustomerService CustomerService

@*
    SCM DB Manager > Customers (root CLAUDE.md §8) — reference data feeding System
    composition (§2 hierarchy: Customer + Product -> System). Inline list/add/delete
    using TelerikGrid (SCM3.Web/CLAUDE.md Telerik rule).
*@
<PageTitle>Customers · SCM3 Portal</PageTitle>

<div class="p-3">
    <h1>Customers</h1>
    <p class="text-muted">Reference data used when composing Systems (Customer + Product).</p>

    @if (_statusMessage is not null)
    {
        <p class="alert alert-info">@_statusMessage</p>
    }

    @if (_loading)
    {
        <p class="text-muted">Loading customers…</p>
    }
    else
    {
        <TelerikGrid Data="@_customers"
                     EditMode="Telerik.Blazor.GridEditMode.Inline"
                     OnUpdate="@OnUpdate"
                     OnCreate="@OnCreate"
                     OnDelete="@OnDelete">
            <GridToolBarTemplate>
                <GridCommandButton Command="Add">Add Customer</GridCommandButton>
            </GridToolBarTemplate>
            <GridColumns>
                <GridColumn Field="@nameof(Customer.Name)" Title="Name" />
                <GridCommandColumn>
                    <GridCommandButton Command="Edit">Edit</GridCommandButton>
                    <GridCommandButton Command="Delete">Delete</GridCommandButton>
                    <GridCommandButton Command="Save" ShowInEdit="true">Save</GridCommandButton>
                    <GridCommandButton Command="Cancel" ShowInEdit="true">Cancel</GridCommandButton>
                </GridCommandColumn>
            </GridColumns>
        </TelerikGrid>
    }
</div>

@code {
    private List<Customer> _customers = [];
    private bool _loading = true;
    private bool _busy;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _customers = await CustomerService.GetAllAsync();
        _loading = false;
    }

    private async Task OnCreate(GridCommandEventArgs args)
    {
        var customer = (Customer)args.Item;
        if (string.IsNullOrWhiteSpace(customer.Name)) return;
        await CustomerService.SaveAsync(customer);
        await LoadAsync();
        _statusMessage = $"Added \"{customer.Name}\".";
    }

    private async Task OnUpdate(GridCommandEventArgs args)
    {
        var customer = (Customer)args.Item;
        await CustomerService.SaveAsync(customer);
        await LoadAsync();
        _statusMessage = $"Saved \"{customer.Name}\".";
    }

    private async Task OnDelete(GridCommandEventArgs args)
    {
        var customer = (Customer)args.Item;
        await CustomerService.DeleteAsync(customer.CustomerId);
        await LoadAsync();
        _statusMessage = $"Deleted \"{customer.Name}\".";
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        _busy = true;
        _statusMessage = null;
        try
        {
            await action();
        }
        finally
        {
            _busy = false;
        }
    }
}
