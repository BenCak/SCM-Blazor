<!DOCTYPE html>
<html lang="en" data-scm3-theme="@(_theme.IsDark ? "dark" : "light")"
      data-bs-theme="@(_theme.IsDark ? "dark" : "light")">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["SCM3.Web.styles.css"]" />
    <link id="telerik-theme-css" rel="stylesheet" href="@_theme.CssHref" />
    <link rel="stylesheet" href="@Assets["css/scm3.dark.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    @* Global Interactive Server render mode (root CLAUDE.md "-int Server" — no per-page/Auto
       modes). Pages that instead set their own @rendermode become separate interactive
       "islands" outside MainLayout's static render tree, so its <TelerikRootComponent>
       cascading value never reaches them — surfaced as "requires a TelerikRootComponent". *@
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="_content/Telerik.UI.for.Blazor/js/telerik-blazor.js" defer></script>
    <script src="@Assets["js/scm3.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    [Inject] private ICurrentUserService CurrentUser { get; set; } = default!;

    private ThemeOption _theme = ThemeCatalog.Resolve(ThemeCatalog.DefaultThemeKey);

    // Resolved server-side from Users.Theme so the correct kendo-theme-* stylesheet is
    // present on first paint — avoids a flash of the wrong theme before scm3.applyTheme
    // could run client-side.
    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.LoadAsync();
        _theme = ThemeCatalog.Resolve(CurrentUser.CurrentUser?.Theme);
    }
}
